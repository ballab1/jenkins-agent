@Library('jenkins-sharedlibs')_

pipeline {
    agent { label 's3.ubuntu.home' }

    environment {
        DOCKER_CREDENTIALS_ID = '1a69cdbb-be20-4bde-b30a-87ef9b2db969'
    }

    stages {
        stage('Setup environment') {
            steps {
                sh './build.sh -e'
                script {
                    def props = readProperties file: '.env', interpolate: true
                    echo "DOCKER_REGISTRY: ${props['DOCKER_REGISTRY']},  DOCKER_IMAGE: ${props['TARGET']}"
                }
            }
        }

        stage('Build Image') {
            steps {
                script {
                    def props =  readProperties file: '.env', interpolate: true
                    docker.build("${props['TARGET']}", '.')
                }
            }
        }

        stage('Push Image') {
            steps {
                script {
                    def props =  readProperties file: '.env', interpolate: true
                    docker.withRegistry("https://${props['DOCKER_REGISTRY']}", "${DOCKER_CREDENTIALS_ID}") {
                        docker.image("${props['TARGET']}").push()
                    }
                }
            }
        }
    }

    post {
        always {
            kafkaBuildReporter()
        }
        cleanup {
            deleteDir()
        }
    }
}
